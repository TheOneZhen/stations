{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch",
      "path": "packages/vscode-clipboard-file-paste/",
      "problemMatcher": {
        "owner": "esbuild",
        "source": "esbuild",
        "pattern": {
          "regexp": "^([^:]+):(\\d+):(\\d+):\\s+(error|warning):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Watching for changes\\.\\.\\."
        }
      },
      "isBackground": true,
      "presentation": {
        "reveal": "never",
        "panel": "shared"
      },
      "group": "build",
      "label": "npm: watch - vscode-clipboard-file-paste"
    }
  ]
}
