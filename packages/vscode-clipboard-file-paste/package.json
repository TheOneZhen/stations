{
  "publisher": "zhenisbusy",
  "name": "@zhenisbusy/vscode-clipboard-file-paste",
  "displayName": "Clipboard File Paste",
  "version": "1.0.0",
  "private": true,
  "description": "Paste clipboard files to a configured path and insert a reference at the cursor.",
  "author": "zhenisbusy",
  "license": "MIT",
  "homepage": "https://github.com/zhenisbusy/vscode-clipboard-file-paste",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhenisbusy/vscode-clipboard-file-paste"
  },
  "bugs": {
    "url": "https://github.com/zhenisbusy/vscode-clipboard-file-paste/issues"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "icon": "./res/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "clipboardFilePaste.paste",
        "title": "Paste Clipboard File",
        "category": "Clipboard File Paste"
      }
    ],
    "keybindings": [
      {
        "command": "clipboardFilePaste.paste",
        "key": "ctrl+alt+v",
        "mac": "cmd+alt+v",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "clipboardFilePaste.paste",
          "group": "1_modification@100",
          "when": "editorTextFocus"
        }
      ]
    },
    "configuration": {
      "title": "Clipboard File Paste",
      "properties": {
        "clipboardFilePaste.templates": {
          "type": "object",
          "default": {
            "markdown": {
              "dirname": ".",
              "filename": "[YYYY-MM-DD-HH-mm-ss]",
              "altText": "description",
              "template": "[[altText]]([dirname]/[filename])"
            },
            "html": {
              "dirname": ".",
              "filename": "[YYYY-MM-DD-HH-mm-ss]",
              "altText": "description",
              "template": "<a href=\"[dirname]/[filename]\">[altText]</a>"
            }
          },
          "markdownDescription": "Map VS Code `languageId` to paste settings. `dirname` and `filename` support date/RID placeholders. `template` uses `[dirname]`, `[filename]`, and `[altText]` for the inserted reference."
        },
        "clipboardFilePaste.defaultTextExtension": {
          "type": "string",
          "default": "txt",
          "description": "File extension (without dot) used when pasting plain text from the clipboard."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "test": "vitest run",
    "package": "node esbuild.config.mjs && vsce package --no-dependencies",
    "publish": "node esbuild.config.mjs && vsce publish --no-dependencies"
  },
  "dependencies": {
    "dayjs": "catalog:",
    "sanitize-filename": "^1.6.4"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
