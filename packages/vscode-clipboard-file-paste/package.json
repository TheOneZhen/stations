{
  "publisher": "zhenisbusy",
  "name": "vscode-clipboard-file-paste",
  "displayName": "Clipboard File Paste",
  "version": "0.1.0",
  "description": "Paste clipboard files to a configured path and insert a reference at the cursor.",
  "license": "MIT",
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [],
  "scripts": {
    "compile": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "test": "vitest run",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "dayjs": "catalog:",
    "sanitize-filename": "^1.6.4"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
