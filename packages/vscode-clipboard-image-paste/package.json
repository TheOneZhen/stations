{
  "name": "vscode-clipboard-image-paste",
  "displayName": "Clipboard Image Paste",
  "description": "Paste clipboard images to a configured path and insert a reference at the cursor.",
  "version": "0.1.0",
  "publisher": "zhenisbusy",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "clipboardImagePaste.paste",
        "title": "Paste Clipboard Image",
        "category": "Clipboard Image Paste"
      }
    ],
    "keybindings": [
      {
        "command": "clipboardImagePaste.paste",
        "key": "ctrl+alt+v",
        "mac": "cmd+alt+v",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "clipboardImagePaste.paste",
          "group": "1_modification@100",
          "when": "editorTextFocus"
        }
      ]
    },
    "configuration": {
      "title": "Clipboard Image Paste",
      "properties": {
        "clipboardImagePaste.templates": {
          "type": "object",
          "default": {
            "markdown": "![altText](./images/[YYYY-MM-DD])",
            "html": "<img alt=\"altText\" src=\"./images/[YYYY-MM-DD]\" />"
          },
          "markdownDescription": "Map VS Code `languageId` to insert template. Use `[]` placeholders in paths; literal `altText` is selected after insert."
        },
        "clipboardImagePaste.supportedImageExtensions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "png",
            "jpg",
            "jpeg",
            "gif",
            "webp",
            "svg",
            "bmp"
          ],
          "description": "Allowed output file extensions (lowercase, without dot)."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "test": "vitest run",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.8.2",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.8.3",
    "vitest": "^2.1.6"
  },
  "dependencies": {
    "dayjs": "^1.11.13"
  }
}
